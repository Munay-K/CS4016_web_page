---
import Layout from "./Layout.astro";
import IconLink from "../components/IconLink.astro";
import Tags from "../components/Tags.astro";
import { generateURL } from "../utils";

const { id, title, description, imagen, periodo, integrantes, tags } = Astro.props;

const backLink = Astro.url.pathname.indexOf("/proyectos/") > -1;
---

<Layout
  title={title}
  description={description}
  heroImage={imagen}
>
  {
    backLink && (
      <span class="back-link">
        <IconLink
          name="Back"
          href={generateURL("/proyectos")}
          label="Back"
          extra="Volver"
          back
        />
      </span>
    )
  }

  <article>
    <div class="hero-image">
      {imagen && <img width={1020} height={510} src={imagen} alt={`Imagen del proyecto ${title}`} />}
    </div>

    <div class="prose">
      <div class="title">
        <div class="info">
          <p><strong>Periodo:</strong> {periodo}</p>
          <p><strong>Integrantes:</strong> {integrantes?.join(", ")}</p>
        </div>
        <h1>
          <span transition:name={`post-title-${id}`}>{title}</span>
        </h1>
        <hr />
      </div>
      <slot />
      {tags && <Tags tags={tags} />}
    </div>
  </article>
</Layout>

<style>
  .back-link {
    display: inline-block;
    margin: 12px 0 8px -6px;
  }

  .hero-image {
    margin-bottom: 1rem;
  }

  .hero-image img {
    width: 100%;
    height: auto;
    border-radius: 8px;
  }

  .title .info {
    font-size: 0.95rem;
    color: #555;
    margin-bottom: 0.75rem;
  }

  .title h1 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .title hr {
    margin: 1rem 0;
  }
</style>
